# ── Gemini (Scriptwriter — primary) ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash          # cascade: 2.5-flash → 2.0-flash → 2.5-pro on 503

# ── Groq (Scriptwriter fallback) ──────────────────────────────────────────────
# Free tier at console.groq.com — used when all Gemini models return 503
GROQ_API_KEY=your_groq_api_key_here

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/
MONGO_DB_NAME=automate_yt

# ── Pexels (Stock Footage — primary) ──────────────────────────────────────────
PEXELS_API_KEY=your_pexels_api_key_here

# ── Pixabay (Stock Footage — fallback for gaps Pexels can't cover) ────────────
# Free: https://pixabay.com/api/docs/  (200 req/min)
PIXABAY_API_KEY=your_pixabay_api_key_here

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# ── Voice (edge-tts) ──────────────────────────────────────────────────────────
# No key needed — Microsoft Edge neural TTS is free
TTS_VOICE=en-US-BrianNeural             # friendly, high-energy male voice
TTS_RATE=+10%                           # slightly faster for Shorts pacing

# ── Transcription (faster-whisper) ───────────────────────────────────────────
WHISPER_MODEL_SIZE=base                 # tiny | base | small | medium | large
WHISPER_DEVICE=cpu                      # cpu | cuda

# ── Pipeline Paths ────────────────────────────────────────────────────────────
OUTPUT_AUDIO_DIR=output/audio
OUTPUT_VIDEO_DIR=output/video

# ── Video Config ──────────────────────────────────────────────────────────────
VIDEO_RESOLUTION_W=1080
VIDEO_RESOLUTION_H=1920                 # 9:16 portrait for Shorts
VIDEO_FPS=30

# ── Channel Strategy ──────────────────────────────────────────────────────────
# Lock the channel to ONE tight sub-niche so YouTube builds a strong topic signal.
# Narrower = faster compounding. Not "psychology" → "dark psychology tactics".
# Not "philosophy" → "stoic philosophy and self-discipline for modern men".
# Empty = open mode (any trending topic) — algorithm never classifies the channel.
CHANNEL_NICHE=stoic philosophy and self-discipline for English-speaking men aged 18-35

# Pin a RECURRING FORMAT so every video feels like the same series. This drives
# binge + subscribe behavior and differentiates from generic automated channels.
# The trend researcher and scriptwriter both respect this format when set.
#
# How to write a good format: one sentence, episode-shaped, with a fill-in-the-blank
# slot where the specific topic goes. Think of it as a series title template.
#
# Example: "One stoic rule that fixes one specific modern struggle (procrastination,
#           social anxiety, being ignored, lack of discipline)."
#
# Leave blank to let the model free-form within CHANNEL_NICHE.
CHANNEL_FORMAT=One stoic rule that fixes one specific modern struggle

# ── Daily Auto-Upload Scheduler ───────────────────────────────────────────────
# Used by scripts/daily_run.py (triggered by launchd / cron).
# POST_TIME : HH:MM in 24h format — the time to publish each day.
# POST_TZ   : Your timezone offset from UTC in decimal hours.
#             Examples: UTC=0, IST=+5.5, EST=-5, PST=-8, SGT=+8
# Best windows: educational/stoic → 7–9am or 7–9pm in audience timezone.
# Pick ONE slot, hold it 30 days, then let analytics tell you the winner.
# 08:00 IST = 02:30 UTC = 21:30 EST (previous day)
# Catches US late-evening scroll + UK overnight + India early morning —
# optimal for global English stoic/discipline content targeting men 18-35.
POST_TIME=08:00
POST_TZ=+5.5

# Optional: Slack or Discord webhook URL — fires a message if the daily run fails.
# Leave blank to disable.
ALERT_WEBHOOK_URL=

# ── Analytics Feedback Loop ───────────────────────────────────────────────────
# After uploading, run:  python -m src.analytics.youtube_analytics --refresh-all
# to pull retention + CTR for every uploaded video. The first run will trigger
# OAuth re-consent because of the new analytics scopes.
